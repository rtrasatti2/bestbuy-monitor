{
  "name": "bestbuy-open-box-monitor",
  "version": "1.0.0",
  "description": "Intelligent agent that monitors Best Buy for Open Box - Excellent LG G5 OLED deals, checking 4 times per day and sending alerts",
  "main": "bestbuy_monitor.js",
  "scripts": {
    "start": "node bestbuy_monitor.js",
    "dev": "nodemon bestbuy_monitor.js",
    "pm2:start": "pm2 start bestbuy_monitor.js --name 'bestbuy-monitor'",
    "pm2:stop": "pm2 stop bestbuy-monitor",
    "pm2:restart": "pm2 restart bestbuy-monitor",
    "pm2:logs": "pm2 logs bestbuy-monitor",
    "pm2:delete": "pm2 delete bestbuy-monitor",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "web": "vite",
    "web:build": "vite build",
    "web:preview": "vite preview",
    "test": "node --eval \"console.log('No tests configured')\""
  },
  "keywords": [
    "bestbuy",
    "monitor",
    "open-box",
    "lg-g5",
    "oled",
    "deals",
    "alerts",
    "ai",
    "claude",
    "anthropic"
  ],
  "author": "Best Buy Monitor Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3"
  },
  "optionalDependencies": {
    "@sendgrid/mail": "^8.1.0",
    "twilio": "^4.10.0",
    "discord.js": "^14.14.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "lucide-react": "^0.344.0",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.17"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/bestbuy-monitor"
  },
  "bugs": {
    "url": "https://github.com/your-username/bestbuy-monitor/issues"
  },
  "homepage": "https://github.com/your-username/bestbuy-monitor#readme"
}
