# Best Buy Monitor - Environment Configuration
# Copy this file as .env and fill in your values

# ============================================================================
# REQUIRED: Anthropic API
# ============================================================================
# Get your API key at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=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

# ============================================================================
# SEARCH PARAMETERS
# ============================================================================
# Area code or zip code to search near
AREA_CODE=19040

# Product to monitor (exact or partial model names work)
PRODUCT_MODEL=LG G5 OLED

# Condition to filter by
CONDITION=Open Box - Excellent

# ============================================================================
# CHECK FREQUENCY
# ============================================================================
# How many hours between each check (for 4 checks/day, use 6)
# Options: 4 (6/day), 6 (4/day), 8 (3/day), 12 (2/day), 24 (1/day)
CHECK_INTERVAL_HOURS=6

# ============================================================================
# OPTIONAL: Price & Distance Filters
# ============================================================================
# Maximum price to alert on (leave empty for no limit)
# Example: 1200 for $1,200 max
MAX_PRICE=

# Maximum distance in miles to search (leave empty for no limit)
# Example: 30 for 30 miles max
MAX_DISTANCE_MILES=

# Minimum quantity required to trigger alert
MIN_QUANTITY=1

# ============================================================================
# OPTIONAL: Slack Notifications
# ============================================================================
# Slack Webhook URL for alerts
# Create webhook: https://api.slack.com/messaging/webhooks
# Example: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
SLACK_WEBHOOK_URL=

# ============================================================================
# OPTIONAL: Discord Notifications
# ============================================================================
# Discord Webhook URL for alerts
# Create webhook: Server Settings > Integrations > Webhooks
# Example: https://discord.com/api/webhooks/1234567890/abcdefghijklmnopqrstuvwxyz
DISCORD_WEBHOOK_URL=

# ============================================================================
# OPTIONAL: Email Notifications (SendGrid)
# ============================================================================
# SendGrid API Key for email alerts
# Get key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# Email address to send alerts to
ALERT_EMAIL=your.email@example.com

# ============================================================================
# OPTIONAL: Twilio SMS Notifications
# ============================================================================
# Twilio Account SID
# Get at: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=

# Twilio Auth Token
TWILIO_AUTH_TOKEN=

# Twilio phone number (with + prefix)
# Example: +15551234567
TWILIO_FROM_NUMBER=

# Your phone number to receive SMS (with + prefix)
# Example: +15559876543
TWILIO_TO_NUMBER=

# ============================================================================
# OPTIONAL: Advanced Settings
# ============================================================================
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable dry-run mode (checks without sending alerts)
DRY_RUN=false

# Timeout for API requests (milliseconds)
API_TIMEOUT=30000

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit this file to git (add .env to .gitignore)
# 2. Use strong, unique API keys and tokens
# 3. Rotate keys periodically
# 4. For production: use a secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)
# 5. Leave notification URLs blank to disable that notification type
